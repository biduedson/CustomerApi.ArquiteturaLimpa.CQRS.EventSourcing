<MudPaper Class="empty-state" Elevation="0">
    <MudStack AlignItems="AlignItems.Center" Spacing="2">
        <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Secondary" />
        <MudText Typo="Typo.h5"><b>@Title</b></MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">@Description</MudText>
        @ChildContent
    </MudStack>
</MudPaper>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
