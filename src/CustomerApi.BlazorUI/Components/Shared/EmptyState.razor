<div class="empty-state">
    <h3>@Title</h3>
    <p>@Description</p>
    @ChildContent
</div>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
