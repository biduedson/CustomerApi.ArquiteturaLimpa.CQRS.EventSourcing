@using CustomerApi.BlazorUI.Models.Users

@if (User is not null)
{
    <div class="modal-backdrop-shell" @onclick="Close">
        <section class="management-modal" @onclick:stopPropagation="true">
            <header class="modal-header-clean">
                <div>
                    <p class="eyebrow mb-1">Usuário</p>
                    <h2>@User.FullName</h2>
                    <p class="text-muted mb-0">@User.Email</p>
                </div>
                <button class="btn-close" type="button" aria-label="Fechar" @onclick="Close"></button>
            </header>

            <div class="modal-summary-grid">
                <div>
                    <span>Username</span>
                    <strong>@User.UserName</strong>
                </div>
                <div>
                    <span>Role</span>
                    <strong>@User.Role</strong>
                </div>
                <div>
                    <span>Status</span>
                    <strong>@(User.IsActive ? "Ativo" : "Inativo")</strong>
                </div>
            </div>

            <div class="modal-tabs">
                <button class="modal-tab @(GetTabClass("profile"))" type="button" @onclick='() => _tab = "profile"'>Perfil</button>
                <button class="modal-tab @(GetTabClass("role"))" type="button" disabled="@(!CanManage)" @onclick='() => _tab = "role"'>Permissão</button>
                <button class="modal-tab @(GetTabClass("danger"))" type="button" disabled="@(!CanDelete)" @onclick='() => _tab = "danger"'>Excluir</button>
            </div>

            @if (_tab == "profile")
            {
                <EditForm Model="_profileModel" OnValidSubmit="SaveProfileAsync">
                    <AntiforgeryToken />
                    <DataAnnotationsValidator />
                    <ValidationSummary class="validation-box" />

                    @if (ErrorMessages.Count > 0)
                    {
                        <div class="api-error-box">
                            @foreach (var error in ErrorMessages)
                            {
                                <div>@error</div>
                            }
                        </div>
                    }

                    <div class="row g-3">
                        <div class="col-md-7">
                            <label class="form-label">Nome completo</label>
                            <InputText class="form-control" @bind-Value="_profileModel.FullName" disabled="@(!CanManage)" />
                            <ValidationMessage For="() => _profileModel.FullName" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Cargo</label>
                            <InputText class="form-control" @bind-Value="_profileModel.JobTitle" disabled="@(!CanManage)" />
                            <ValidationMessage For="() => _profileModel.JobTitle" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Nascimento</label>
                            <InputDate class="form-control" @bind-Value="_profileModel.DateOfBirth" disabled="@(!CanManage)" />
                            <ValidationMessage For="() => _profileModel.DateOfBirth" />
                        </div>
                    </div>

                    <div class="modal-actions">
                        <button class="btn btn-light" type="button" @onclick="Close">Cancelar</button>
                        <button class="btn btn-primary" type="submit" disabled="@(!CanManage)">Salvar perfil</button>
                    </div>
                </EditForm>
            }
            else if (_tab == "role")
            {
                <EditForm Model="_roleModel" OnValidSubmit="SaveRoleAsync">
                    <AntiforgeryToken />
                    <DataAnnotationsValidator />
                    <ValidationSummary class="validation-box" />

                    @if (ErrorMessages.Count > 0)
                    {
                        <div class="api-error-box">
                            @foreach (var error in ErrorMessages)
                            {
                                <div>@error</div>
                            }
                        </div>
                    }

                    <label class="form-label">Role de acesso</label>
                    <InputSelect class="form-select" @bind-Value="_roleModel.Role" disabled="@(!CanManage)">
                        <option value="1">Viewer</option>
                        <option value="2">Operator</option>
                        <option value="3">Admin</option>
                    </InputSelect>

                    <div class="modal-actions">
                        <button class="btn btn-light" type="button" @onclick="Close">Cancelar</button>
                        <button class="btn btn-primary" type="submit" disabled="@(!CanManage)">Atualizar role</button>
                    </div>
                </EditForm>
            }
            else
            {
                <div class="danger-panel">
                    <h3>Excluir usuário</h3>
                    <p>Essa ação remove o usuário do fluxo de gestão. O próprio usuário logado não pode se excluir.</p>
                    <div class="modal-actions">
                        <button class="btn btn-light" type="button" @onclick="Close">Cancelar</button>
                        <button class="btn btn-danger" type="button" disabled="@(!CanDelete)" @onclick="DeleteAsync">Excluir usuário</button>
                    </div>
                </div>
            }
        </section>
    </div>
}

@code {
    private string _tab = "profile";
    private UserProfileFormModel _profileModel = new();
    private UpdateUserRoleRequest _roleModel = new();

    [Parameter] public UserListItem? User { get; set; }
    [Parameter] public bool CanManage { get; set; }
    [Parameter] public bool CanDelete { get; set; }
    [Parameter] public IReadOnlyList<string> ErrorMessages { get; set; } = [];
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<UpdateUserProfileRequest> OnSaveProfile { get; set; }
    [Parameter] public EventCallback<UpdateUserRoleRequest> OnSaveRole { get; set; }
    [Parameter] public EventCallback<Guid> OnDelete { get; set; }

    protected override void OnParametersSet()
    {
        if (User is null)
            return;

        _profileModel = new()
        {
            Id = User.Id,
            FullName = User.FullName,
            DateOfBirth = User.DateOfBirth,
            JobTitle = User.JobTitle
        };

        _roleModel = new()
        {
            Id = User.Id,
            Role = ParseRole(User.Role)
        };
    }

    private async Task SaveProfileAsync()
    {
        if (_profileModel.DateOfBirth is null)
            return;

        await OnSaveProfile.InvokeAsync(new UpdateUserProfileRequest
        {
            Id = _profileModel.Id,
            FullName = _profileModel.FullName,
            DateOfBirth = _profileModel.DateOfBirth.Value,
            JobTitle = _profileModel.JobTitle
        });
    }

    private async Task SaveRoleAsync() => await OnSaveRole.InvokeAsync(_roleModel);

    private async Task DeleteAsync()
    {
        if (User is not null)
            await OnDelete.InvokeAsync(User.Id);
    }

    private async Task Close() => await OnClose.InvokeAsync();

    private string GetTabClass(string tab) => _tab == tab ? "active" : string.Empty;

    private static int ParseRole(string role) =>
        role.Equals("Admin", StringComparison.OrdinalIgnoreCase) ? 3 :
        role.Equals("Operator", StringComparison.OrdinalIgnoreCase) ? 2 : 1;
}
