@using CustomerApi.BlazorUI.Models.Customers

<div class="mobile-card-list">
    @foreach (var customer in Customers)
    {
        <MudPaper Class="mobile-record-card" Elevation="0">
            <MudStack Spacing="2">
                <MudStack Row AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                    <MudStack Spacing="0">
                        <MudText><b>@customer.FirstName @customer.LastName</b></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@customer.Email</MudText>
                    </MudStack>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary">@customer.Gender</MudChip>
                </MudStack>

                <MudDivider />

                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Nascimento</MudText>
                    <MudText>@customer.DateOfBirth.ToString("dd/MM/yyyy")</MudText>
                </MudStack>

                <MudStack Row Spacing="1">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               FullWidth="true"
                               OnClick="() => OnManage.InvokeAsync(customer)">
                        Gerenciar
                    </MudButton>
                    @if (CanDelete)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   FullWidth="true"
                                   OnClick="() => OnDelete.InvokeAsync(customer)">
                            Excluir
                        </MudButton>
                    }
                </MudStack>
            </MudStack>
        </MudPaper>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<CustomerListItem> Customers { get; set; } = [];
    [Parameter] public bool CanDelete { get; set; }
    [Parameter] public EventCallback<CustomerListItem> OnManage { get; set; }
    [Parameter] public EventCallback<CustomerListItem> OnDelete { get; set; }
}
