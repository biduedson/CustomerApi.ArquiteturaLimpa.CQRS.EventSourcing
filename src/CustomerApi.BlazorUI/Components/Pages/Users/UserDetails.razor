@using CustomerApi.BlazorUI.Models.Users
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Operator")]
@page "/users/{Id:guid}"
@inject CustomerApi.BlazorUI.Services.ApiClients.Users.IUserApiClient UserApi
@inject CustomerApi.BlazorUI.Services.Notifications.ToastService Toast
@inject NavigationManager Navigation

<PageTitle>Detalhes do usuario</PageTitle>

@if (_loading)
{
    <SkeletonCard />
}
else if (_user is not null)
{
    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="page-heading">
        <MudStack Spacing="1">
            <MudText Class="eyebrow">Usuario</MudText>
            <MudText Typo="Typo.h3"><b>@_user.FullName</b></MudText>
            <MudText Color="Color.Secondary">@_user.Email</MudText>
        </MudStack>
        <MudStack Row Spacing="2">
            <MudButton Href="users" Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.ArrowBack">Voltar</MudButton>
            <AuthorizeView Roles="Admin">
                <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="OpenDeleteConfirmation">
                    Excluir
                </MudButton>
            </AuthorizeView>
        </MudStack>
    </MudStack>

    <MudPaper Class="form-card" Elevation="0">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Nome de usuario</MudText>
                <MudText><b>@_user.UserName</b></MudText>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Role</MudText>
                <MudText><b>@_user.Role</b></MudText>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Cargo</MudText>
                <MudText><b>@_user.JobTitle</b></MudText>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Nascimento</MudText>
                <MudText><b>@_user.DateOfBirth.ToString("dd/MM/yyyy")</b></MudText>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                <MudChip T="string" Color="@(_user.IsActive ? Color.Success : Color.Default)" Variant="Variant.Filled">
                    @(_user.IsActive ? "Ativo" : "Inativo")
                </MudChip>
            </MudItem>
        </MudGrid>
    </MudPaper>
}

<ConfirmDeleteModal IsOpen="@(_showDeleteConfirmation && _user is not null)"
                    IsBusy="_deleting"
                    Title="Confirmar exclusao"
                    ItemName="@DeleteUserName"
                    Message="Essa acao remove o usuario do fluxo de gestao. Deseja realmente excluir?"
                    ConfirmButtonText="Excluir usuario"
                    ErrorMessages="_modalErrors"
                    OnCancel="CloseDeleteConfirmation"
                    OnConfirm="DeleteConfirmedAsync" />

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _loading = true;
    private bool _deleting;
    private bool _showDeleteConfirmation;
    private UserListItem? _user;
    private List<string> _modalErrors = [];
    private string DeleteUserName => _user?.FullName ?? string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var response = await UserApi.GetByIdAsync(Id);
        _user = response.Result;
        _loading = false;

        if (_user is null)
        {
            Toast.Error("Usuario nao encontrado.");
            Navigation.NavigateTo("/users");
        }
    }

    private async Task DeleteConfirmedAsync()
    {
        _modalErrors = [];
        _deleting = true;
        var response = await UserApi.DeleteAsync(Id);
        _deleting = false;

        if (response.Success)
        {
            Toast.Success("Usuario removido com sucesso.");
            Navigation.NavigateTo("/users");
            return;
        }

        _modalErrors = response.ErrorMessages.Count > 0 ? response.ErrorMessages : ["Nao foi possivel concluir a operacao."];
        Toast.Error(string.Join(" ", _modalErrors));
    }

    private void OpenDeleteConfirmation()
    {
        _modalErrors = [];
        _showDeleteConfirmation = true;
    }

    private void CloseDeleteConfirmation()
    {
        _modalErrors = [];
        _showDeleteConfirmation = false;
    }
}
