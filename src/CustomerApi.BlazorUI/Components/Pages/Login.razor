@page "/login"
@layout Layout.AuthLayout
@attribute [AllowAnonymous]
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<div class="login-page">
    <section class="login-panel">
        <MudPaper Class="login-story" Elevation="0">
            <MudStack Spacing="3">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="login-brand">
                    <MudAvatar Class="brand-mark" Size="Size.Large">C</MudAvatar>
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle1"><b>CustomerApi</b></MudText>
                        <MudText Typo="Typo.caption">Clean Architecture UI</MudText>
                    </MudStack>
                </MudStack>

                <MudText Class="eyebrow">CQRS + Event Sourcing</MudText>
                <MudText Typo="Typo.h3"><b>Controle clientes com uma interface alinhada a sua API.</b></MudText>
                <MudText Typo="Typo.body1" Class="lead">
                    Painel Blazor para operar clientes e usuarios sobre uma solucao com DDD,
                    MediatR, validacoes, persistencia SQL, MongoDB e Redis.
                </MudText>

                <div class="login-highlights">
                    <span>Clean Architecture</span>
                    <span>JWT + Cookies</span>
                    <span>.NET 9</span>
                </div>
            </MudStack>
        </MudPaper>

        <MudPaper Class="login-card" Elevation="0">
            <MudStack Spacing="3">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="login-brand login-brand-form">
                    <MudAvatar Class="brand-mark" Size="Size.Large">C</MudAvatar>
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle1"><b>CustomerApi CRM</b></MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Acesso administrativo</MudText>
                    </MudStack>
                </MudStack>

                <div>
                    <MudText Typo="Typo.h4"><b>Entrar</b></MudText>
                    <MudText Color="Color.Secondary">Use sua conta do sistema para acessar o painel de clientes.</MudText>
                </div>

                @if (HasError)
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                        Email ou senha invalidos. Confira os dados e tente novamente.
                    </MudAlert>
                }

                <form method="post" action="/auth/login">
                    <AntiforgeryToken />

                    <MudStack Spacing="3">
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Email</MudText>
                            <input class="form-control form-control-lg" name="email" type="email" autocomplete="username" required />
                        </div>

                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Senha</MudText>
                            <input class="form-control form-control-lg" name="password" type="password" autocomplete="current-password" required />
                        </div>

                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   FullWidth="true"
                                   EndIcon="@Icons.Material.Filled.Login">
                            Entrar no sistema
                        </MudButton>
                    </MudStack>
                </form>
            </MudStack>
        </MudPaper>
    </section>
</div>

@code {
    private bool HasError => Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("error", StringComparison.OrdinalIgnoreCase);
}
