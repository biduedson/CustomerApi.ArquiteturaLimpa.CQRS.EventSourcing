@using CustomerApi.BlazorUI.Models.Customers

@if (Customer is not null)
{
    <div class="modal-backdrop-shell" @onclick="Close">
        <MudPaper Class="management-modal" Elevation="0" @onclick:stopPropagation="true">
            <header class="modal-header-clean">
                <div>
                    <MudText Class="eyebrow">Cliente</MudText>
                    <MudText Typo="Typo.h5"><b>@Customer.FirstName @Customer.LastName</b></MudText>
                    <MudText Color="Color.Secondary">@Customer.Email</MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Secondary" OnClick="Close" />
            </header>

            <div class="modal-summary-grid">
                <div>
                    <span>Genero</span>
                    <strong>@Customer.Gender</strong>
                </div>
                <div>
                    <span>Nascimento</span>
                    <strong>@Customer.DateOfBirth.ToString("dd/MM/yyyy")</strong>
                </div>
                <div>
                    <span>Id</span>
                    <strong class="text-truncate">@Customer.Id</strong>
                </div>
            </div>

            <MudTabs @bind-ActivePanelIndex="_tabIndex" Rounded="true" Elevation="0" Class="mb-3">
                <MudTabPanel Text="Detalhes" Icon="@Icons.Material.Filled.Badge">
                    <div class="detail-list mt-3">
                        <div><span>Nome</span><strong>@Customer.FirstName @Customer.LastName</strong></div>
                        <div><span>Email</span><strong>@Customer.Email</strong></div>
                        <div><span>Genero</span><strong>@Customer.Gender</strong></div>
                        <div><span>Nascimento</span><strong>@Customer.DateOfBirth.ToString("dd/MM/yyyy")</strong></div>
                    </div>
                </MudTabPanel>
                <MudTabPanel Text="Atualizar" Icon="@Icons.Material.Filled.Edit">
                    <EditForm Model="_model" OnValidSubmit="SaveAsync">
                        <AntiforgeryToken />
                        <DataAnnotationsValidator />
                        <ValidationSummary class="validation-box" />

                        @if (ErrorMessages.Count > 0)
                        {
                            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
                                @foreach (var error in ErrorMessages)
                                {
                                    <div>@error</div>
                                }
                            </MudAlert>
                        }

                        <MudTextField @bind-Value="_model.Email" Label="Email" Variant="Variant.Outlined" For="() => _model.Email" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                            A rota atual de clientes aceita atualizacao apenas do email.
                        </MudText>

                        <MudStack Row Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Close">Cancelar</MudButton>
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">
                                Salvar alteracao
                            </MudButton>
                        </MudStack>
                    </EditForm>
                </MudTabPanel>
                <MudTabPanel Text="Excluir" Icon="@Icons.Material.Filled.Delete" Disabled="@(!CanDelete)">
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                        Essa acao remove o cliente pelo endpoint protegido para Admin.
                    </MudAlert>
                    <MudStack Row Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Close">Cancelar</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Error" Disabled="@(!CanDelete)" OnClick="DeleteAsync">
                            Excluir cliente
                        </MudButton>
                    </MudStack>
                </MudTabPanel>
            </MudTabs>
        </MudPaper>
    </div>
}

@code {
    private int _tabIndex;
    private UpdateCustomerRequest _model = new();

    [Parameter] public CustomerListItem? Customer { get; set; }
    [Parameter] public bool CanDelete { get; set; }
    [Parameter] public IReadOnlyList<string> ErrorMessages { get; set; } = [];
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<UpdateCustomerRequest> OnSave { get; set; }
    [Parameter] public EventCallback<Guid> OnDelete { get; set; }

    protected override void OnParametersSet()
    {
        if (Customer is null)
            return;

        _model = new()
        {
            Id = Customer.Id,
            Email = Customer.Email
        };
    }

    private async Task SaveAsync() => await OnSave.InvokeAsync(_model);

    private async Task DeleteAsync()
    {
        if (Customer is not null)
            await OnDelete.InvokeAsync(Customer.Id);
    }

    private async Task Close() => await OnClose.InvokeAsync();
}
