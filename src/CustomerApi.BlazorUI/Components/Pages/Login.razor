@page "/login"
@layout Layout.AuthLayout
@attribute [AllowAnonymous]
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<div class="login-page">
    <section class="login-panel">
        <div class="login-story">
            <div class="login-brand">
                <span class="brand-mark">C</span>
                <div>
                    <strong>CustomerApi</strong>
                    <small>Clean Architecture UI</small>
                </div>
            </div>

            <p class="eyebrow">CQRS + Event Sourcing</p>
            <h1>Controle clientes com uma interface alinhada a sua API.</h1>
            <p class="lead">
                Painel Blazor para operar clientes e usuários sobre uma solução com DDD,
                MediatR, validações, persistência SQL, MongoDB e Redis.
            </p>

            <div class="login-highlights">
                <span>Clean Architecture</span>
                <span>JWT + Cookies</span>
                <span>.NET 9</span>
            </div>
        </div>

        <div class="login-card shadow-lg">
            <div class="login-brand login-brand-form">
                <span class="brand-mark">C</span>
                <div>
                    <strong>CustomerApi CRM</strong>
                    <small>Acesso administrativo</small>
                </div>
            </div>

            <h2>Entrar</h2>
            <p class="text-muted">Use sua conta do sistema para acessar o painel de clientes.</p>

            @if (HasError)
            {
                <div class="alert alert-danger rounded-4">
                    Email ou senha inválidos. Confira os dados e tente novamente.
                </div>
            }

            <form method="post" action="/auth/login" class="mt-4">
                <AntiforgeryToken />

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input class="form-control form-control-lg" name="email" type="email" autocomplete="username" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Senha</label>
                    <input class="form-control form-control-lg" name="password" type="password" autocomplete="current-password" required />
                </div>

                <button class="btn btn-primary btn-lg rounded-pill w-100" type="submit">
                    Entrar no sistema
                </button>
            </form>
        </div>
    </section>
</div>

@code {
    private bool HasError => Navigation.ToAbsoluteUri(Navigation.Uri).Query.Contains("error", StringComparison.OrdinalIgnoreCase);
}
