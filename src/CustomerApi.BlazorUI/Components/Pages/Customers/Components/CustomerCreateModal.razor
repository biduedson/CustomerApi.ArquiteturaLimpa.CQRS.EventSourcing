@using CustomerApi.BlazorUI.Models.Customers

@if (IsOpen)
{
    <div class="modal-backdrop-shell" @onclick="Close">
        <MudPaper Class="management-modal" Elevation="0" @onclick:stopPropagation="true">
            <header class="modal-header-clean">
                <div>
                    <MudText Class="eyebrow">Novo cliente</MudText>
                    <MudText Typo="Typo.h5"><b>Cadastrar cliente</b></MudText>
                    <MudText Color="Color.Secondary">Registra um cliente no fluxo principal da API.</MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Secondary" OnClick="Close" />
            </header>

            <EditForm Model="_model" OnValidSubmit="SaveAsync">
                <AntiforgeryToken />
                <DataAnnotationsValidator />
                <ValidationSummary class="validation-box" />

                @if (ErrorMessages.Count > 0)
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
                        @foreach (var error in ErrorMessages)
                        {
                            <div>@error</div>
                        }
                    </MudAlert>
                }

                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.FirstName" Label="Nome" Variant="Variant.Outlined" For="() => _model.FirstName" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.LastName" Label="Sobrenome" Variant="Variant.Outlined" For="() => _model.LastName" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Email" Label="Email" Variant="Variant.Outlined" For="() => _model.Email" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect @bind-Value="_model.Gender" Label="Genero" Variant="Variant.Outlined" For="() => _model.Gender">
                            <MudSelectItem Value="@("Male")">Masculino</MudSelectItem>
                            <MudSelectItem Value="@("Female")">Feminino</MudSelectItem>
                            <MudSelectItem Value="@("Other")">Outro</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudDatePicker @bind-Date="_model.DateOfBirth" Label="Nascimento" Variant="Variant.Outlined" For="() => _model.DateOfBirth" />
                    </MudItem>
                </MudGrid>

                <MudStack Row Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Close">Cancelar</MudButton>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">
                        Criar cliente
                    </MudButton>
                </MudStack>
            </EditForm>
        </MudPaper>
    </div>
}

@code {
    private CustomerFormModel _model = new();

    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public IReadOnlyList<string> ErrorMessages { get; set; } = [];
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<CreateCustomerRequest> OnSave { get; set; }

    private async Task SaveAsync()
    {
        if (_model.DateOfBirth is null)
            return;

        await OnSave.InvokeAsync(new CreateCustomerRequest
        {
            FirstName = _model.FirstName,
            LastName = _model.LastName,
            Gender = _model.Gender,
            Email = _model.Email,
            DateOfBirth = _model.DateOfBirth.Value
        });

        _model = new();
    }

    private async Task Close() => await OnClose.InvokeAsync();
}
