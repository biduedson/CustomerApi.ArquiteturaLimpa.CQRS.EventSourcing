@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider


<nav class="nav flex-column app-nav">
    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">Dashboard</NavLink>
    <NavLink class="nav-link" href="customers">Clientes</NavLink>
    <NavLink class="nav-link" href="customers/new">Novo cliente</NavLink>
    <NavLink class="nav-link" href="users">Usuários</NavLink>
</nav>

<div class="sidebar-auth mt-auto">
    <AuthorizeView>
        <Authorized>
            <div class="small text-white-50 mb-2">Logado como</div>
            <strong>@context.User.Identity?.Name</strong>
            <form method="post" action="/auth/logout" class="mt-3">
                <button class="btn btn-sm btn-outline-light rounded-pill w-100" type="submit">Sair</button>
            </form>
        </Authorized>
        <NotAuthorized>
            <a class="btn btn-sm btn-light rounded-pill w-100" href="login">Entrar</a>
        </NotAuthorized>
    </AuthorizeView>
</div>
