@using CustomerApi.BlazorUI.Models.Users
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Operator")]
@page "/users/{Id:guid}"
@inject CustomerApi.BlazorUI.Services.IUserApiClient UserApi
@inject CustomerApi.BlazorUI.Services.ToastService Toast
@inject NavigationManager Navigation

<PageTitle>Detalhes do usuário</PageTitle>

@if (_loading)
{
    <div class="skeleton-card"></div>
}
else if (_user is not null)
{
    <div class="page-heading">
        <div>
            <p class="eyebrow">Usuário</p>
            <h1>@_user.FullName</h1>
            <p class="text-muted">@_user.Email</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-light rounded-pill px-4" href="users">Voltar</a>
            <AuthorizeView Roles="Admin">
                <button class="btn btn-outline-danger rounded-pill px-4" @onclick="OpenDeleteConfirmation">Excluir</button>
            </AuthorizeView>
        </div>
    </div>

    <div class="form-card">
        <div class="row g-3">
            <div class="col-md-6">
                <span class="text-muted d-block">Nome de usuário</span>
                <strong>@_user.UserName</strong>
            </div>
            <div class="col-md-6">
                <span class="text-muted d-block">Role</span>
                <strong>@_user.Role</strong>
            </div>
            <div class="col-md-6">
                <span class="text-muted d-block">Cargo</span>
                <strong>@_user.JobTitle</strong>
            </div>
            <div class="col-md-6">
                <span class="text-muted d-block">Nascimento</span>
                <strong>@_user.DateOfBirth.ToString("dd/MM/yyyy")</strong>
            </div>
            <div class="col-md-6">
                <span class="text-muted d-block">Status</span>
                <strong>@(_user.IsActive ? "Ativo" : "Inativo")</strong>
            </div>
        </div>
    </div>
}

<ConfirmDeleteModal IsOpen="@(_showDeleteConfirmation && _user is not null)"
                    IsBusy="_deleting"
                    Title="Confirmar exclusao"
                    ItemName="@DeleteUserName"
                    Message="Essa acao remove o usuario do fluxo de gestao. Deseja realmente excluir?"
                    ConfirmButtonText="Excluir usuario"
                    ErrorMessages="_modalErrors"
                    OnCancel="CloseDeleteConfirmation"
                    OnConfirm="DeleteConfirmedAsync" />

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _loading = true;
    private bool _deleting;
    private bool _showDeleteConfirmation;
    private UserListItem? _user;
    private List<string> _modalErrors = [];
    private string DeleteUserName => _user?.FullName ?? string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var response = await UserApi.GetByIdAsync(Id);
        _user = response.Result;
        _loading = false;

        if (_user is null)
        {
            Toast.Error("Usuário não encontrado.");
            Navigation.NavigateTo("/users");
        }
    }

    private async Task DeleteConfirmedAsync()
    {
        _modalErrors = [];
        _deleting = true;
        var response = await UserApi.DeleteAsync(Id);
        _deleting = false;

        if (response.Success)
        {
            Toast.Success("Usuário removido com sucesso.");
            Navigation.NavigateTo("/users");
            return;
        }

        _modalErrors = response.ErrorMessages.Count > 0 ? response.ErrorMessages : ["Nao foi possivel concluir a operacao."];
        Toast.Error(string.Join(" ", _modalErrors));
    }

    private void OpenDeleteConfirmation()
    {
        _modalErrors = [];
        _showDeleteConfirmation = true;
    }

    private void CloseDeleteConfirmation()
    {
        _modalErrors = [];
        _showDeleteConfirmation = false;
    }
}
