@using CustomerApi.BlazorUI.Models.Users

<div class="mobile-card-list">
    @foreach (var user in Users)
    {
        <MudPaper Class="mobile-record-card" Elevation="0">
            <MudStack Spacing="2">
                <MudStack Row AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                    <MudStack Spacing="0">
                        <MudText><b>@user.FullName</b></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@user.UserName</MudText>
                    </MudStack>
                    <MudChip T="string" Size="Size.Small" Color="@(user.IsActive ? Color.Success : Color.Default)" Variant="Variant.Filled">
                        @(user.IsActive ? "Ativo" : "Inativo")
                    </MudChip>
                </MudStack>

                <MudDivider />

                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Email</MudText>
                    <MudText>@user.Email</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Cargo</MudText>
                    <MudText>@user.JobTitle</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Role</MudText>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary">@user.Role</MudChip>
                </MudStack>

                <MudStack Row Spacing="1">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" OnClick="() => OnManage.InvokeAsync(user)">
                        Gerenciar
                    </MudButton>
                    @if (CanDelete)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   FullWidth="true"
                                   Disabled="@IsDeleteDisabled(user)"
                                   OnClick="() => OnDelete.InvokeAsync(user)">
                            Excluir
                        </MudButton>
                    }
                </MudStack>
            </MudStack>
        </MudPaper>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<UserListItem> Users { get; set; } = [];
    [Parameter] public bool CanDelete { get; set; }
    [Parameter] public Guid? AuthenticatedUserId { get; set; }
    [Parameter] public EventCallback<UserListItem> OnManage { get; set; }
    [Parameter] public EventCallback<UserListItem> OnDelete { get; set; }

    private bool IsDeleteDisabled(UserListItem user) => user.Id == AuthenticatedUserId;
}
