@using CustomerApi.BlazorUI.Models.Users

@if (IsOpen)
{
    <div class="modal-backdrop-shell" @onclick="Close">
        <MudPaper Class="management-modal" Elevation="0" @onclick:stopPropagation="true">
            <header class="modal-header-clean">
                <div>
                    <MudText Class="eyebrow">Novo acesso</MudText>
                    <MudText Typo="Typo.h5"><b>Cadastrar usuario</b></MudText>
                    <MudText Color="Color.Secondary">Cria um usuario no write side e publica no read side.</MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Secondary" OnClick="Close" />
            </header>

            <EditForm Model="_model" OnValidSubmit="SaveAsync">
                <AntiforgeryToken />
                <DataAnnotationsValidator />
                <ValidationSummary class="validation-box" />

                @if (ErrorMessages.Count > 0)
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
                        @foreach (var error in ErrorMessages)
                        {
                            <div>@error</div>
                        }
                    </MudAlert>
                }

                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Username" Label="Username" Variant="Variant.Outlined" For="() => _model.Username" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Email" Label="Email" Variant="Variant.Outlined" For="() => _model.Email" />
                    </MudItem>
                    <MudItem xs="12" md="7">
                        <MudTextField @bind-Value="_model.FullName" Label="Nome completo" Variant="Variant.Outlined" For="() => _model.FullName" />
                    </MudItem>
                    <MudItem xs="12" md="5">
                        <MudTextField @bind-Value="_model.JobTitle" Label="Cargo" Variant="Variant.Outlined" For="() => _model.JobTitle" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect @bind-Value="_model.Role" Label="Role" Variant="Variant.Outlined" For="() => _model.Role">
                            <MudSelectItem Value="1">Viewer</MudSelectItem>
                            <MudSelectItem Value="2">Operator</MudSelectItem>
                            <MudSelectItem Value="3">Admin</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudDatePicker @bind-Date="_model.DateOfBirth" Label="Nascimento" Variant="Variant.Outlined" For="() => _model.DateOfBirth" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="_model.Password" Label="Senha inicial" InputType="InputType.Password" Variant="Variant.Outlined" For="() => _model.Password" />
                    </MudItem>
                </MudGrid>

                <MudStack Row Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Close">Cancelar</MudButton>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">
                        Criar usuario
                    </MudButton>
                </MudStack>
            </EditForm>
        </MudPaper>
    </div>
}

@code {
    private UserCreateFormModel _model = new();

    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public IReadOnlyList<string> ErrorMessages { get; set; } = [];
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<CreateUserRequest> OnSave { get; set; }

    private async Task SaveAsync()
    {
        if (_model.DateOfBirth is null)
            return;

        await OnSave.InvokeAsync(new CreateUserRequest
        {
            Username = _model.Username,
            Email = _model.Email,
            Role = _model.Role,
            FullName = _model.FullName,
            DateOfBirth = _model.DateOfBirth.Value,
            JobTitle = _model.JobTitle,
            Password = _model.Password
        });

        _model = new();
    }

    private async Task Close() => await OnClose.InvokeAsync();
}
