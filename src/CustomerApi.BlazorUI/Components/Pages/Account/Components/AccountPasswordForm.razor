<section class="work-card profile-grid-wide">
    <p class="eyebrow">Senha</p>
    <h2>Trocar senha</h2>
    <form method="post" action="/account/changepassword">
        <AntiforgeryToken />

        @if (ErrorMessage is not null)
        {
            <div class="api-error-box">
                <div>@ErrorMessage</div>
            </div>
        }

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Senha atual</label>
                <input name="currentPassword" type="password" class="form-control" autocomplete="current-password" maxlength="100" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">Nova senha</label>
                <input name="newPassword" type="password" class="form-control" autocomplete="new-password" maxlength="100" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">Confirmar senha</label>
                <input name="confirmPassword" type="password" class="form-control" autocomplete="new-password" maxlength="100" required />
            </div>
        </div>

        <div class="modal-actions">
            <button class="btn btn-primary" type="submit">Atualizar senha</button>
        </div>
    </form>
</section>

@code {
    [Parameter] public string? ErrorMessage { get; set; }
}
