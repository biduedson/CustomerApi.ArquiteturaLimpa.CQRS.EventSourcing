@using CustomerApi.BlazorUI.Models.Customers

<ManagementPageHeader Eyebrow="Formulario"
                      Title="@Title"
                      Description="Os dados serao enviados para a WebApi e processados via MediatR." />

<EditForm Model="Model" OnValidSubmit="OnValidSubmit">
    <AntiforgeryToken />
    <DataAnnotationsValidator />

    <MudPaper Class="form-card" Elevation="0">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="Model.FirstName" Label="Nome" Variant="Variant.Outlined" For="() => Model.FirstName" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="Model.LastName" Label="Sobrenome" Variant="Variant.Outlined" For="() => Model.LastName" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="Model.Email" Label="Email" Variant="Variant.Outlined" For="() => Model.Email" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect @bind-Value="Model.Gender" Label="Genero" Variant="Variant.Outlined" For="() => Model.Gender">
                    <MudSelectItem Value="@("Male")">Masculino</MudSelectItem>
                    <MudSelectItem Value="@("Female")">Feminino</MudSelectItem>
                    <MudSelectItem Value="@("Other")">Outro</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudDatePicker @bind-Date="Model.DateOfBirth" Label="Nascimento" Variant="Variant.Outlined" For="() => Model.DateOfBirth" />
            </MudItem>
        </MudGrid>

        <MudStack Row Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
            <MudButton Href="customers" Variant="Variant.Outlined" Color="Color.Secondary">Cancelar</MudButton>
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">Salvar</MudButton>
        </MudStack>
    </MudPaper>
</EditForm>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter, EditorRequired] public CustomerFormModel Model { get; set; } = new();
    [Parameter, EditorRequired] public EventCallback OnValidSubmit { get; set; }
}
