<div class="page-heading">
    <div>
        <p class="eyebrow">@Eyebrow</p>
        <h1>@Title</h1>
        <p class="text-muted">@Description</p>
    </div>
    @if (!string.IsNullOrWhiteSpace(ButtonText) && OnButtonClick.HasDelegate)
    {
        <AuthorizeView Roles="Admin,Operator">
            <button class="btn btn-primary rounded-pill" type="button" @onclick="HandleButtonClick">@ButtonText</button>
        </AuthorizeView>
    }
</div>

@code {
    [Parameter] public string Eyebrow { get; set; } = string.Empty;
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public string ButtonText { get; set; } = string.Empty;
    [Parameter] public EventCallback OnButtonClick { get; set; }

    private async Task HandleButtonClick()
    {
        await OnButtonClick.InvokeAsync();
    }
}
