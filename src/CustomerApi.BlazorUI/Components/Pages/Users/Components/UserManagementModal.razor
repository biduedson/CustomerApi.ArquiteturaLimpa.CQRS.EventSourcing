@using CustomerApi.BlazorUI.Models.Users

@if (User is not null)
{
    <div class="modal-backdrop-shell" @onclick="Close">
        <MudPaper Class="management-modal" Elevation="0" @onclick:stopPropagation="true">
            <header class="modal-header-clean">
                <div>
                    <MudText Class="eyebrow">Usuario</MudText>
                    <MudText Typo="Typo.h5"><b>@User.FullName</b></MudText>
                    <MudText Color="Color.Secondary">@User.Email</MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Secondary" OnClick="Close" />
            </header>

            <div class="modal-summary-grid">
                <div>
                    <span>Username</span>
                    <strong>@User.UserName</strong>
                </div>
                <div>
                    <span>Role</span>
                    <strong>@User.Role</strong>
                </div>
                <div>
                    <span>Status</span>
                    <strong>@(User.IsActive ? "Ativo" : "Inativo")</strong>
                </div>
            </div>

            <MudTabs @bind-ActivePanelIndex="_tabIndex" Rounded="true" Elevation="0" Class="mb-3">
                <MudTabPanel Text="Perfil" Icon="@Icons.Material.Filled.Person">
                    <EditForm Model="_profileModel" OnValidSubmit="SaveProfileAsync">
                        <AntiforgeryToken />
                        <DataAnnotationsValidator />
                        <ValidationSummary class="validation-box" />

                        @if (ErrorMessages.Count > 0)
                        {
                            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
                                @foreach (var error in ErrorMessages)
                                {
                                    <div>@error</div>
                                }
                            </MudAlert>
                        }

                        <MudGrid>
                            <MudItem xs="12" md="7">
                                <MudTextField @bind-Value="_profileModel.FullName" Label="Nome completo" Disabled="@(!CanManage)" Variant="Variant.Outlined" For="() => _profileModel.FullName" />
                            </MudItem>
                            <MudItem xs="12" md="5">
                                <MudTextField @bind-Value="_profileModel.JobTitle" Label="Cargo" Disabled="@(!CanManage)" Variant="Variant.Outlined" For="() => _profileModel.JobTitle" />
                            </MudItem>
                            <MudItem xs="12" md="5">
                                <MudDatePicker @bind-Date="_profileModel.DateOfBirth" Label="Nascimento" Disabled="@(!CanManage)" Variant="Variant.Outlined" For="() => _profileModel.DateOfBirth" />
                            </MudItem>
                        </MudGrid>

                        <MudStack Row Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Close">Cancelar</MudButton>
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!CanManage)">
                                Salvar perfil
                            </MudButton>
                        </MudStack>
                    </EditForm>
                </MudTabPanel>
                <MudTabPanel Text="Permissao" Icon="@Icons.Material.Filled.Security" Disabled="@(!CanManage)">
                    <EditForm Model="_roleModel" OnValidSubmit="SaveRoleAsync">
                        <AntiforgeryToken />
                        <DataAnnotationsValidator />
                        <ValidationSummary class="validation-box" />

                        @if (ErrorMessages.Count > 0)
                        {
                            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
                                @foreach (var error in ErrorMessages)
                                {
                                    <div>@error</div>
                                }
                            </MudAlert>
                        }

                        <MudSelect @bind-Value="_roleModel.Role" Label="Role de acesso" Disabled="@(!CanManage)" Variant="Variant.Outlined">
                            <MudSelectItem Value="1">Viewer</MudSelectItem>
                            <MudSelectItem Value="2">Operator</MudSelectItem>
                            <MudSelectItem Value="3">Admin</MudSelectItem>
                        </MudSelect>

                        <MudStack Row Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Close">Cancelar</MudButton>
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!CanManage)">
                                Atualizar role
                            </MudButton>
                        </MudStack>
                    </EditForm>
                </MudTabPanel>
                <MudTabPanel Text="Excluir" Icon="@Icons.Material.Filled.Delete" Disabled="@(!CanDelete)">
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                        Essa acao remove o usuario do fluxo de gestao. O proprio usuario logado nao pode se excluir.
                    </MudAlert>
                    <MudStack Row Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Close">Cancelar</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Error" Disabled="@(!CanDelete)" OnClick="DeleteAsync">
                            Excluir usuario
                        </MudButton>
                    </MudStack>
                </MudTabPanel>
            </MudTabs>
        </MudPaper>
    </div>
}

@code {
    private int _tabIndex;
    private UserProfileFormModel _profileModel = new();
    private UpdateUserRoleRequest _roleModel = new();

    [Parameter] public UserListItem? User { get; set; }
    [Parameter] public bool CanManage { get; set; }
    [Parameter] public bool CanDelete { get; set; }
    [Parameter] public IReadOnlyList<string> ErrorMessages { get; set; } = [];
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<UpdateUserProfileRequest> OnSaveProfile { get; set; }
    [Parameter] public EventCallback<UpdateUserRoleRequest> OnSaveRole { get; set; }
    [Parameter] public EventCallback<Guid> OnDelete { get; set; }

    protected override void OnParametersSet()
    {
        if (User is null)
            return;

        _profileModel = new()
        {
            Id = User.Id,
            FullName = User.FullName,
            DateOfBirth = User.DateOfBirth,
            JobTitle = User.JobTitle
        };

        _roleModel = new()
        {
            Id = User.Id,
            Role = ParseRole(User.Role)
        };
    }

    private async Task SaveProfileAsync()
    {
        if (_profileModel.DateOfBirth is null)
            return;

        await OnSaveProfile.InvokeAsync(new UpdateUserProfileRequest
        {
            Id = _profileModel.Id,
            FullName = _profileModel.FullName,
            DateOfBirth = _profileModel.DateOfBirth.Value,
            JobTitle = _profileModel.JobTitle
        });
    }

    private async Task SaveRoleAsync() => await OnSaveRole.InvokeAsync(_roleModel);

    private async Task DeleteAsync()
    {
        if (User is not null)
            await OnDelete.InvokeAsync(User.Id);
    }

    private async Task Close() => await OnClose.InvokeAsync();

    private static int ParseRole(string role) =>
        role.Equals("Admin", StringComparison.OrdinalIgnoreCase) ? 3 :
        role.Equals("Operator", StringComparison.OrdinalIgnoreCase) ? 2 : 1;
}
