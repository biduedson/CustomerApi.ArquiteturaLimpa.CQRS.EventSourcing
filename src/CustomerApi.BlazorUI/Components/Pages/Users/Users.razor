@using CustomerApi.BlazorUI.Models.Users
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@attribute [Authorize(Roles = "Admin,Operator")]
@page "/users"
@inject CustomerApi.BlazorUI.Services.IUserApiClient UserApi
@inject CustomerApi.BlazorUI.Services.ToastService Toast
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Usuários</PageTitle>

<div class="page-heading">
    <div>
        <p class="eyebrow">Acesso</p>
        <h1>Usuários</h1>
        <p class="text-muted">Gestão de usuários, perfis e permissões da API.</p>
    </div>
    <AuthorizeView Roles="Admin,Operator">
        <button class="btn btn-primary rounded-pill" type="button" @onclick="OpenCreateModal">Novo usuário</button>
    </AuthorizeView>
</div>

@if (_loading)
{
    <div class="skeleton-card"></div>
}
else if (_users.Count == 0)
{
    <div class="empty-state">
        <h3>Nenhum usuário encontrado</h3>
        <p>Os usuários aparecerão aqui quando existirem no read side.</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Cargo</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var user in _users)
                {
                    <tr>
                        <td>
                            <strong>@user.FullName</strong>
                            <div class="small text-muted">@user.UserName</div>
                        </td>
                        <td>@user.Email</td>
                        <td>@user.JobTitle</td>
                        <td><span class="badge text-bg-light">@user.Role</span></td>
                        <td>
                            <span class="badge @(user.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                @(user.IsActive ? "Ativo" : "Inativo")
                            </span>
                        </td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => OpenUserModal(user)">Gerenciar</button>
                            <AuthorizeView Roles="Admin">
                                <button class="btn btn-sm btn-outline-danger" disabled="@IsDeleteDisabled(user)" @onclick="() => DeleteAsync(user.Id)">Excluir</button>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

<UserManagementModal User="_selectedUser"
                     CanManage="_isAdmin"
                     CanDelete="@CanDeleteSelectedUser"
                     ErrorMessages="_modalErrors"
                     OnClose="CloseUserModal"
                     OnSaveProfile="UpdateProfileAsync"
                     OnSaveRole="UpdateRoleAsync"
                     OnDelete="DeleteAsync" />

<UserCreateModal IsOpen="_showCreateModal"
                 ErrorMessages="_modalErrors"
                 OnClose="CloseCreateModal"
                 OnSave="CreateAsync" />

@code {
    private bool _loading = true;
    private List<UserListItem> _users = [];
    private Guid? _authenticatedUserId;
    private bool _isAdmin;
    private UserListItem? _selectedUser;
    private bool _showCreateModal;
    private List<string> _modalErrors = [];

    private bool CanDeleteSelectedUser => _selectedUser is not null && !IsDeleteDisabled(_selectedUser);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var response = await UserApi.GetAllAsync();
        _users = response.Result?.ToList() ?? [];
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var authenticatedUser = authState.User;
        _isAdmin = authenticatedUser.IsInRole("Admin");
        _authenticatedUserId = GetAuthenticatedUserId(authenticatedUser);
        _loading = false;

        if (!response.Success)
            Toast.Error(string.Join(" ", response.ErrorMessages));
    }

    private async Task DeleteAsync(Guid id)
    {
        _modalErrors = [];

        if (!_isAdmin || id == _authenticatedUserId)
            return;

        var response = await UserApi.DeleteAsync(id);
        if (response.Success)
        {
            Toast.Success("Usuário removido com sucesso.");
            _selectedUser = null;
            await LoadAsync();
            return;
        }

        ShowApiErrors(response.ErrorMessages);
    }

    private async Task CreateAsync(CreateUserRequest request)
    {
        _modalErrors = [];
        var response = await UserApi.CreateAsync(request);
        if (response.Success)
        {
            Toast.Success("Usuário cadastrado com sucesso.");
            _showCreateModal = false;
            await LoadAsync();
            return;
        }

        ShowApiErrors(response.ErrorMessages);
    }

    private async Task UpdateProfileAsync(UpdateUserProfileRequest request)
    {
        _modalErrors = [];

        if (!_isAdmin)
            return;

        var response = await UserApi.UpdateProfileAsync(request);
        if (response.Success)
        {
            Toast.Success("Perfil atualizado com sucesso.");
            _selectedUser = null;
            await LoadAsync();
            return;
        }

        ShowApiErrors(response.ErrorMessages);
    }

    private async Task UpdateRoleAsync(UpdateUserRoleRequest request)
    {
        _modalErrors = [];

        if (!_isAdmin)
            return;

        var response = await UserApi.UpdateRoleAsync(request);
        if (response.Success)
        {
            Toast.Success("Role atualizada com sucesso.");
            _selectedUser = null;
            await LoadAsync();
            return;
        }

        ShowApiErrors(response.ErrorMessages);
    }

    private bool IsDeleteDisabled(UserListItem user)
    {
        return !_isAdmin || user.Id == _authenticatedUserId;
    }

    private void OpenUserModal(UserListItem user)
    {
        _modalErrors = [];
        _selectedUser = user;
    }

    private void CloseUserModal()
    {
        _modalErrors = [];
        _selectedUser = null;
    }

    private void OpenCreateModal()
    {
        _modalErrors = [];
        _showCreateModal = true;
    }

    private void CloseCreateModal()
    {
        _modalErrors = [];
        _showCreateModal = false;
    }

    private void ShowApiErrors(List<string> errors)
    {
        _modalErrors = errors.Count > 0 ? errors : ["Não foi possível concluir a operação."];
        Toast.Error(string.Join(" ", _modalErrors));
    }

    private static Guid? GetAuthenticatedUserId(ClaimsPrincipal user)
    {
        var userId = user.FindFirstValue(ClaimTypes.NameIdentifier);
        return Guid.TryParse(userId, out var id) ? id : null;
    }
}
