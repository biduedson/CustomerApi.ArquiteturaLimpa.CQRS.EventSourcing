@page "/"
@attribute [Authorize]

<MudPaper Class="hero-card" Elevation="0">
    <MudStack Spacing="3">
        <MudText Class="eyebrow">CustomerApi UI</MudText>
        <MudText Typo="Typo.h2"><b>Interface Blazor para sua API Clean Architecture</b></MudText>
        <MudText Typo="Typo.h6" Class="lead">Dashboard moderno consumindo sua WebApi com DDD, CQRS, Redis, MongoDB e SQL.</MudText>
        <MudButton Href="customers"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   EndIcon="@Icons.Material.Filled.ArrowForward">
            Gerenciar clientes
        </MudButton>
    </MudStack>
</MudPaper>

<MudGrid Class="mt-4">
    <MudItem xs="12" md="4">
        <MudPaper Class="metric-card" Elevation="0">
            <MudText Color="Color.Secondary">Arquitetura</MudText>
            <MudText Typo="Typo.h5"><b>Clean</b></MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudPaper Class="metric-card" Elevation="0">
            <MudText Color="Color.Secondary">Backend</MudText>
            <MudText Typo="Typo.h5"><b>.NET 9 API</b></MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudPaper Class="metric-card" Elevation="0">
            <MudText Color="Color.Secondary">Frontend</MudText>
            <MudText Typo="Typo.h5"><b>Blazor + MudBlazor</b></MudText>
        </MudPaper>
    </MudItem>
</MudGrid>
