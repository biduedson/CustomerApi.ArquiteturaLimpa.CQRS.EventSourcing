@implements IDisposable
@inject CustomerApi.BlazorUI.Services.Notifications.ToastService ToastService
@inject ISnackbar Snackbar

@code {
    protected override void OnInitialized()
    {
        ToastService.OnShow += Show;
    }

    private void Show(string type, string message)
    {
        var severity = type switch
        {
            "success" => Severity.Success,
            "danger" => Severity.Error,
            "warning" => Severity.Warning,
            _ => Severity.Info
        };

        Snackbar.Add(message, severity);
    }

    public void Dispose() => ToastService.OnShow -= Show;
}
