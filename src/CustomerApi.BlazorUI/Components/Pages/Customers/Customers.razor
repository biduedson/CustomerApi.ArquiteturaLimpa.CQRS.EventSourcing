@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using CustomerApi.BlazorUI.Models.Customers
@using CustomerApi.BlazorUI.Components.Pages.Customers.Components
@attribute [Authorize(Roles = "Admin,Operator,Viewer")]
@page "/customers"
@inject CustomerApi.BlazorUI.Services.ApiClients.Customers.ICustomerApiClient CustomerApi
@inject CustomerApi.BlazorUI.Services.Notifications.ToastService Toast
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Clientes</PageTitle>

<ManagementPageHeader Eyebrow="Cadastro" Title="Clientes" ButtonText="Novo cliente"
                      Description="Consulta e manutenção do read side da sua API CQRS." OnButtonClick="OpenCreateModal" />
@if (_loading)
{
    <SkeletonCard />
}
else if (_customers.Count == 0)
{
    <EmptyState Title="Nenhum cliente encontrado"
                Description="Crie o primeiro cliente para validar o fluxo completo da UI para a API.">
        <AuthorizeView Roles="Admin,Operator">
            <button class="btn btn-primary rounded-pill" type="button" @onclick="OpenCreateModal">Cadastrar cliente</button>
        </AuthorizeView>
    </EmptyState>

}
else
{
    <div class="responsive-table-view">
        <CustomerTable Customers="_customers" CanDelete="_isAdmin" OnManage="OpenCustomerModal"
                       OnDelete="OpenDeleteConfirmation" />
    </div>
    <div class="responsive-card-view">
        <CustomerCardList Customers="_customers" CanDelete="_isAdmin" OnManage="OpenCustomerModal"
                          OnDelete="OpenDeleteConfirmation" />
    </div>
}

<CustomerManagementModal Customer="_selectedCustomer" CanDelete="_isAdmin" ErrorMessages="_modalErrors"
                         OnClose="CloseCustomerModal" OnSave="UpdateAsync" OnDelete="OpenDeleteConfirmation" />

<CustomerCreateModal IsOpen="_showCreateModal" ErrorMessages="_modalErrors" OnClose="CloseCreateModal"
                     OnSave="CreateAsync" />

<ConfirmDeleteModal IsOpen="@(_customerPendingDelete is not null)" IsBusy="_deleting" Title="Confirmar exclusao"
                    ItemName="@DeleteCustomerName" Message="Essa acao remove o cliente definitivamente. Deseja realmente excluir?"
                    ConfirmButtonText="Excluir cliente" ErrorMessages="_modalErrors" OnCancel="CloseDeleteConfirmation"
                    OnConfirm="DeleteConfirmedAsync" />

@code {
    private bool _loading = true;
    private bool _isAdmin;
    private bool _deleting;
    private List<CustomerListItem> _customers = [];
    private CustomerListItem? _selectedCustomer;
    private CustomerListItem? _customerPendingDelete;
    private bool _showCreateModal;
    private List<string> _modalErrors = [];
    private string DeleteCustomerName => _customerPendingDelete is null
        ? string.Empty
        : $"{_customerPendingDelete.FirstName} {_customerPendingDelete.LastName}";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var response = await CustomerApi.GetAllAsync();

        _customers = response.Result?.ToList() ?? [];
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _isAdmin = authState.User.IsInRole("Admin");
        _loading = false;
    }

    private async Task CreateAsync(CreateCustomerRequest request)
    {
        _modalErrors = [];
        var response = await CustomerApi.CreateAsync(request);
        if (response.Success)
        {
            Toast.Success("Cliente cadastrado com sucesso.");
            _showCreateModal = false;
            await LoadAsync();
            return;
        }

        ShowApiErrors(response.ErrorMessages);
    }

    private async Task UpdateAsync(UpdateCustomerRequest request)
    {
        _modalErrors = [];
        var response = await CustomerApi.UpdateAsync(request);
        if (response.Success)
        {
            Toast.Success("Cliente atualizado com sucesso.");
            _selectedCustomer = null;
            await LoadAsync();
            return;
        }

        ShowApiErrors(response.ErrorMessages);
    }

    private async Task DeleteConfirmedAsync()
    {
        if (_customerPendingDelete is null)
            return;

        _modalErrors = [];
        _deleting = true;
        var response = await CustomerApi.DeleteAsync(_customerPendingDelete.Id);
        _deleting = false;

        if (response.Success)
        {
            Toast.Success("Cliente removido com sucesso.");
            _selectedCustomer = null;
            _customerPendingDelete = null;
            await LoadAsync();
            return;
        }

        ShowApiErrors(response.ErrorMessages);
    }

    private void OpenCustomerModal(CustomerListItem customer)
    {
        _modalErrors = [];
        _selectedCustomer = customer;
    }

    private void CloseCustomerModal()
    {
        _modalErrors = [];
        _selectedCustomer = null;
    }

    private void OpenDeleteConfirmation(CustomerListItem customer)
    {
        _modalErrors = [];
        _customerPendingDelete = customer;
    }

    private void OpenDeleteConfirmation(Guid id)
    {
        var customer = _customers.FirstOrDefault(customer => customer.Id == id);
        if (customer is not null)
            OpenDeleteConfirmation(customer);
    }

    private void CloseDeleteConfirmation()
    {
        _modalErrors = [];
        _customerPendingDelete = null;
    }

    private void OpenCreateModal()
    {
        _modalErrors = [];
        _showCreateModal = true;
    }

    private void CloseCreateModal()
    {
        _modalErrors = [];
        _showCreateModal = false;
    }

    private void ShowApiErrors(List<string> errors)
    {
        _modalErrors = errors.Count > 0 ? errors : ["Não foi possível concluir a operação."];
        Toast.Error(string.Join(" ", _modalErrors));
    }
}
