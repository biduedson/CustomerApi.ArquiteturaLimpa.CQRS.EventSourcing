@using CustomerApi.BlazorUI.Components.Pages.Account.Components
@using CustomerApi.BlazorUI.Models.Account
@using CustomerApi.BlazorUI.Models.Users
@using System.Security.Claims
@attribute [Authorize]
@page "/account"
@inject CustomerApi.BlazorUI.Services.ApiClients.Users.IUserApiClient UserApi
@inject CustomerApi.BlazorUI.Services.ApiClients.Account.IAccountApiClient AccountApi
@inject CustomerApi.BlazorUI.Services.Notifications.ToastService Toast
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Meu perfil</PageTitle>

<ManagementPageHeader Eyebrow="Conta" Title="Meu perfil"
                      Description="Dados e credenciais do usuário autenticado." />

@if (_loading)
{
    <SkeletonCard />
}
else
{
    <div class="profile-grid">
        <AccountIdentityCard User="_currentUser" Email="_email" />
        <AccountEmailForm Model="_emailModel" ErrorMessages="_emailErrors" OnValidSubmit="ChangeEmailAsync" />
        <AccountPasswordForm ErrorMessage="PasswordErrorMessage" />
    </div>
}

@code {
    private bool _loading = true;
    private string _email = string.Empty;
    private UserListItem? _currentUser;
    private ChangeEmailRequest _emailModel = new();
    private List<string> _emailErrors = [];

    private string? PasswordErrorMessage
    {
        get
        {
            var query = Navigation.ToAbsoluteUri(Navigation.Uri).Query;

            if (!query.Contains("changePasswordError", StringComparison.OrdinalIgnoreCase))
                return null;

            if (query.Contains("required", StringComparison.OrdinalIgnoreCase))
                return "Informe a senha atual, a nova senha e a confirmação.";

            if (query.Contains("confirm", StringComparison.OrdinalIgnoreCase))
                return "A confirmação da nova senha não corresponde à nova senha informada.";

            return "Não foi possível alterar a senha. Confira a senha atual e tente novamente.";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var principal = authState.User;
        _email = principal.FindFirstValue(ClaimTypes.Email) ?? principal.Identity?.Name ?? string.Empty;
        _emailModel.Email = _email;

        var userIdValue = principal.FindFirstValue(ClaimTypes.NameIdentifier);
        if (Guid.TryParse(userIdValue, out var userId))
        {
            var response = await UserApi.GetByIdAsync(userId);
            _currentUser = response.Result;
            if (_currentUser is not null)
                _emailModel.Email = _currentUser.Email;
        }

        _loading = false;
    }

    private async Task ChangeEmailAsync()
    {
        _emailErrors = [];
        var response = await AccountApi.ChangeEmailAsync(_emailModel);
        if (response.Success)
        {
            Toast.Success("Email alterado. Faça login novamente para renovar a sessão.");
            return;
        }

        _emailErrors = response.ErrorMessages.Count > 0
            ? response.ErrorMessages
            : ["Não foi possível alterar o email."];

        Toast.Error(string.Join(" ", _emailErrors));
    }
}
