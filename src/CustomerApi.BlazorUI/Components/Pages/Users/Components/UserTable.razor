@using CustomerApi.BlazorUI.Models.Users

<MudPaper Class="work-card" Elevation="0">
    <MudTable Items="Users" Hover="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Nome</MudTh>
            <MudTh>Email</MudTh>
            <MudTh>Cargo</MudTh>
            <MudTh>Role</MudTh>
            <MudTh>Status</MudTh>
            <MudTh Class="text-end">Acoes</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Nome">
                <MudText><b>@context.FullName</b></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.UserName</MudText>
            </MudTd>
            <MudTd DataLabel="Email">@context.Email</MudTd>
            <MudTd DataLabel="Cargo">@context.JobTitle</MudTd>
            <MudTd DataLabel="Role">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary">@context.Role</MudChip>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)" Variant="Variant.Filled">
                    @(context.IsActive ? "Ativo" : "Inativo")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Acoes" Class="text-end">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="() => OnManage.InvokeAsync(context)">
                    Gerenciar
                </MudButton>
                @if (CanDelete)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               Size="Size.Small"
                               Class="ms-2"
                               Disabled="@IsDeleteDisabled(context)"
                               OnClick="() => OnDelete.InvokeAsync(context)">
                        Excluir
                    </MudButton>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudPaper>

@code {
    [Parameter] public IReadOnlyList<UserListItem> Users { get; set; } = [];
    [Parameter] public bool CanDelete { get; set; }
    [Parameter] public Guid? AuthenticatedUserId { get; set; }
    [Parameter] public EventCallback<UserListItem> OnManage { get; set; }
    [Parameter] public EventCallback<UserListItem> OnDelete { get; set; }

    private bool IsDeleteDisabled(UserListItem user) => user.Id == AuthenticatedUserId;
}
