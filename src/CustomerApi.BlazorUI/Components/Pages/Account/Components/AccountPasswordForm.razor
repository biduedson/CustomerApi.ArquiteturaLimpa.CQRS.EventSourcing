@using CustomerApi.BlazorUI.Models.Account

<MudPaper Class="work-card profile-grid-wide" Elevation="0">
    <MudStack Spacing="3">
        <div>
            <MudText Class="eyebrow">Senha</MudText>
            <MudText Typo="Typo.h5"><b>Trocar senha</b></MudText>
        </div>

        <EditForm Model="Model" OnValidSubmit="OnValidSubmit">
            <AntiforgeryToken />
            <DataAnnotationsValidator />
            <ValidationSummary class="validation-box" />

            @if (ErrorMessages.Count > 0)
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
                    @foreach (var error in ErrorMessages)
                    {
                        <div>@error</div>
                    }
                </MudAlert>
            }

            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="Model.CurrentPassword"
                                  Label="Senha atual"
                                  InputType="InputType.Password"
                                  Variant="Variant.Outlined"
                                  For="() => Model.CurrentPassword"
                                  autocomplete="current-password" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="Model.NewPassword"
                                  Label="Nova senha"
                                  InputType="InputType.Password"
                                  Variant="Variant.Outlined"
                                  For="() => Model.NewPassword"
                                  autocomplete="new-password" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="Model.ConfirmPassword"
                                  Label="Confirmar senha"
                                  InputType="InputType.Password"
                                  Variant="Variant.Outlined"
                                  For="() => Model.ConfirmPassword"
                                  autocomplete="new-password" />
                </MudItem>
            </MudGrid>

            <MudStack Row Justify="Justify.FlexEnd" Class="mt-4">
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">
                    Atualizar senha
                </MudButton>
            </MudStack>
        </EditForm>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public ChangePasswordRequest Model { get; set; } = new();
    [Parameter] public IReadOnlyCollection<string> ErrorMessages { get; set; } = [];
    [Parameter] public EventCallback OnValidSubmit { get; set; }
}
