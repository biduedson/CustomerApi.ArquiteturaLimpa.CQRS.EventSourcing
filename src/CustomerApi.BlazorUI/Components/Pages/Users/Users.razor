@using CustomerApi.BlazorUI.Models.Users
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Operator")]
@page "/users"
@inject CustomerApi.BlazorUI.Services.IUserApiClient UserApi
@inject CustomerApi.BlazorUI.Services.ToastService Toast

<PageTitle>Usuários</PageTitle>

<div class="page-heading">
    <div>
        <p class="eyebrow">Acesso</p>
        <h1>Usuários</h1>
        <p class="text-muted">Consulta dos usuários do read side.</p>
    </div>
</div>

@if (_loading)
{
    <div class="skeleton-card"></div>
}
else if (_users.Count == 0)
{
    <div class="empty-state">
        <h3>Nenhum usuário encontrado</h3>
        <p>Os usuários aparecerão aqui quando existirem no read side.</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Cargo</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var user in _users)
                {
                    <tr>
                        <td>
                            <strong>@user.FullName</strong>
                            <div class="small text-muted">@user.UserName</div>
                        </td>
                        <td>@user.Email</td>
                        <td>@user.JobTitle</td>
                        <td><span class="badge text-bg-light">@user.Role</span></td>
                        <td>
                            <span class="badge @(user.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                @(user.IsActive ? "Ativo" : "Inativo")
                            </span>
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" href="users/@user.Id">Detalhes</a>
                            <AuthorizeView Roles="Admin">
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(user.Id)">Excluir</button>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private List<UserListItem> _users = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var response = await UserApi.GetAllAsync();
        _users = response.Result?.ToList() ?? [];
        _loading = false;

        if (!response.Success)
            Toast.Error(string.Join(" ", response.Errors));
    }

    private async Task DeleteAsync(Guid id)
    {
        var response = await UserApi.DeleteAsync(id);
        if (response.Success)
        {
            Toast.Success("Usuário removido com sucesso.");
            await LoadAsync();
            return;
        }

        Toast.Error(string.Join(" ", response.Errors));
    }
}
