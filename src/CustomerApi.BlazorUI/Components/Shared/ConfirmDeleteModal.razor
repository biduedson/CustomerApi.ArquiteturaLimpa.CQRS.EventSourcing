@if (IsOpen)
{
    <div class="modal-backdrop-shell" @onclick="CancelAsync">
        <MudPaper Class="confirm-modal" Elevation="0" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="confirm-delete-title">
            <header class="modal-header-clean">
                <div>
                    <MudText Class="eyebrow">@Eyebrow</MudText>
                    <MudText Typo="Typo.h5" id="confirm-delete-title"><b>@Title</b></MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Secondary" Disabled="@IsBusy" OnClick="CancelAsync" />
            </header>

            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                <MudText><b>@ItemName</b></MudText>
                <MudText Typo="Typo.body2">@Message</MudText>
            </MudAlert>

            @if (ErrorMessages.Count > 0)
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mt-3">
                    @foreach (var error in ErrorMessages)
                    {
                        <div>@error</div>
                    }
                </MudAlert>
            }

            <MudStack Row Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Disabled="@IsBusy" OnClick="CancelAsync">Cancelar</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Error" Disabled="@IsBusy" OnClick="ConfirmAsync">
                    @(IsBusy ? BusyText : ConfirmButtonText)
                </MudButton>
            </MudStack>
        </MudPaper>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public string Eyebrow { get; set; } = "Confirmacao";
    [Parameter] public string Title { get; set; } = "Confirmar exclusao";
    [Parameter] public string ItemName { get; set; } = string.Empty;
    [Parameter] public string Message { get; set; } = "Tem certeza que deseja excluir este registro?";
    [Parameter] public string ConfirmButtonText { get; set; } = "Excluir";
    [Parameter] public string BusyText { get; set; } = "Excluindo...";
    [Parameter] public IReadOnlyList<string> ErrorMessages { get; set; } = [];
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnConfirm { get; set; }

    private async Task CancelAsync()
    {
        if (!IsBusy)
            await OnCancel.InvokeAsync();
    }

    private async Task ConfirmAsync()
    {
        if (!IsBusy)
            await OnConfirm.InvokeAsync();
    }
}
