@using CustomerApi.BlazorUI.Models.Customers

@if (Customer is not null)
{
    <div class="modal-backdrop-shell" @onclick="Close">
        <section class="management-modal" @onclick:stopPropagation="true">
            <header class="modal-header-clean">
                <div>
                    <p class="eyebrow mb-1">Cliente</p>
                    <h2>@Customer.FirstName @Customer.LastName</h2>
                    <p class="text-muted mb-0">@Customer.Email</p>
                </div>
                <button class="btn-close" type="button" aria-label="Fechar" @onclick="Close"></button>
            </header>

            <div class="modal-summary-grid">
                <div>
                    <span>Gênero</span>
                    <strong>@Customer.Gender</strong>
                </div>
                <div>
                    <span>Nascimento</span>
                    <strong>@Customer.DateOfBirth.ToString("dd/MM/yyyy")</strong>
                </div>
                <div>
                    <span>Id</span>
                    <strong class="text-truncate">@Customer.Id</strong>
                </div>
            </div>

            <div class="modal-tabs">
                <button class="modal-tab @(GetTabClass("details"))" type="button" @onclick='() => _tab = "details"'>Detalhes</button>
                <button class="modal-tab @(GetTabClass("edit"))" type="button" @onclick='() => _tab = "edit"'>Atualizar</button>
                <button class="modal-tab @(GetTabClass("danger"))" type="button" disabled="@(!CanDelete)" @onclick='() => _tab = "danger"'>Excluir</button>
            </div>

            @if (_tab == "details")
            {
                <div class="detail-list">
                    <div><span>Nome</span><strong>@Customer.FirstName @Customer.LastName</strong></div>
                    <div><span>Email</span><strong>@Customer.Email</strong></div>
                    <div><span>Gênero</span><strong>@Customer.Gender</strong></div>
                    <div><span>Nascimento</span><strong>@Customer.DateOfBirth.ToString("dd/MM/yyyy")</strong></div>
                </div>
            }
            else if (_tab == "edit")
            {
                <EditForm Model="_model" OnValidSubmit="SaveAsync">
                    <AntiforgeryToken />
                    <DataAnnotationsValidator />
                    <ValidationSummary class="validation-box" />

                    @if (ErrorMessages.Count > 0)
                    {
                        <div class="api-error-box">
                            @foreach (var error in ErrorMessages)
                            {
                                <div>@error</div>
                            }
                        </div>
                    }

                    <label class="form-label">Email</label>
                    <InputText class="form-control" @bind-Value="_model.Email" />
                    <ValidationMessage For="() => _model.Email" />
                    <p class="form-hint">A rota atual de clientes aceita atualização apenas do email.</p>

                    <div class="modal-actions">
                        <button class="btn btn-light" type="button" @onclick="Close">Cancelar</button>
                        <button class="btn btn-primary" type="submit">Salvar alteração</button>
                    </div>
                </EditForm>
            }
            else
            {
                <div class="danger-panel">
                    <h3>Excluir cliente</h3>
                    <p>Essa ação remove o cliente pelo endpoint protegido para Admin.</p>
                    <div class="modal-actions">
                        <button class="btn btn-light" type="button" @onclick="Close">Cancelar</button>
                        <button class="btn btn-danger" type="button" disabled="@(!CanDelete)" @onclick="DeleteAsync">Excluir cliente</button>
                    </div>
                </div>
            }
        </section>
    </div>
}

@code {
    private string _tab = "details";
    private UpdateCustomerRequest _model = new();

    [Parameter] public CustomerListItem? Customer { get; set; }
    [Parameter] public bool CanDelete { get; set; }
    [Parameter] public IReadOnlyList<string> ErrorMessages { get; set; } = [];
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<UpdateCustomerRequest> OnSave { get; set; }
    [Parameter] public EventCallback<Guid> OnDelete { get; set; }

    protected override void OnParametersSet()
    {
        if (Customer is null)
            return;

        _model = new()
        {
            Id = Customer.Id,
            Email = Customer.Email
        };
    }

    private async Task SaveAsync() => await OnSave.InvokeAsync(_model);

    private async Task DeleteAsync()
    {
        if (Customer is not null)
            await OnDelete.InvokeAsync(Customer.Id);
    }

    private async Task Close() => await OnClose.InvokeAsync();

    private string GetTabClass(string tab) => _tab == tab ? "active" : string.Empty;
}
