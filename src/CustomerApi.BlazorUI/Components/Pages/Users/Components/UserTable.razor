@using CustomerApi.BlazorUI.Models.Users

<div class="card border-0 shadow-sm rounded-4">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Email</th>
                    <th>Cargo</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Users)
                {
                    <tr>
                        <td>
                            <strong>@user.FullName</strong>
                            <div class="small text-muted">@user.UserName</div>
                        </td>
                        <td>@user.Email</td>
                        <td>@user.JobTitle</td>
                        <td><span class="badge text-bg-light">@user.Role</span></td>
                        <td>
                            <span class="badge @(user.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                @(user.IsActive ? "Ativo" : "Inativo")
                            </span>
                        </td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => OnManage.InvokeAsync(user)">Gerenciar</button>
                            @if (CanDelete)
                            {
                                <button class="btn btn-sm btn-outline-danger" type="button" disabled="@IsDeleteDisabled(user)" @onclick="() => OnDelete.InvokeAsync(user)">Excluir</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<UserListItem> Users { get; set; } = [];
    [Parameter] public bool CanDelete { get; set; }
    [Parameter] public Guid? AuthenticatedUserId { get; set; }
    [Parameter] public EventCallback<UserListItem> OnManage { get; set; }
    [Parameter] public EventCallback<UserListItem> OnDelete { get; set; }

    private bool IsDeleteDisabled(UserListItem user) => user.Id == AuthenticatedUserId;
}
